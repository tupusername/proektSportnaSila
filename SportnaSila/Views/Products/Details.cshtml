@model SportnaSila.Models.Products

<div class="container py-5">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="row g-0">
            @* СНИМКА *@
            <div class="col-md-6 bg-light d-flex align-items-center justify-content-center p-4">
                <img src="@Model.ImgUrl" class="img-fluid rounded-4 shadow-sm" style="max-height: 500px; object-fit: contain;" alt="@Model.Name">
            </div>

            @* ИНФОРМАЦИЯ *@
            <div class="col-md-6 p-4 p-lg-5 d-flex flex-column justify-content-center">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Продукти</a></li>
                        <li class="breadcrumb-item active fw-bold">@Model.Name</li>
                    </ol>
                </nav>

                <h1 class="fw-bold display-5 mb-2">@Model.Name</h1>

                <div class="mb-4">
                    <span class="badge bg-dark px-3 py-2 rounded-pill me-2">Спорт</span>
                    <div class="mt-2">
                        <span class="text-muted small">Марка: <b class="text-dark">@Model.Brand?.BrandName</b></span>
                    </div>
                </div>

                <div class="mb-4">
                    <h5 class="fw-bold text-uppercase small text-muted mb-2">Описание</h5>
                    <p class="text-secondary lh-lg" style="font-size: 1.1rem;">@Model.Description</p>
                </div>

                @* НОВАТА СЕКЦИЯ С ЪП-ДАУН И ЦЕНА *@
                <div class="bg-light p-3 rounded-4 mb-4 border d-flex justify-content-between align-items-center">
                    <div>
                        <label class="form-label fw-bold small text-muted text-uppercase d-block mb-1">Количество</label>
                        <div class="input-group" style="width: 130px;">
                            <button class="btn btn-outline-secondary rounded-start-pill border-0" type="button" onclick="changeQty(-1)">-</button>
                            <input type="number" id="detailQtyInput" class="form-control text-center fw-bold bg-transparent border-0" value="1" min="1" max="@Model.Quantity" readonly>
                            <button class="btn btn-outline-secondary rounded-end-pill border-0" type="button" onclick="changeQty(1)">+</button>
                        </div>
                    </div>
                    <div class="text-end">
                        <label class="form-label fw-bold small text-muted text-uppercase d-block mb-1">Обща цена</label>
                        <h2 class="fw-bold mb-0" id="displayTotalPrice" style="color: #ff4d05;">@Model.Price.ToString("0.00") €</h2>
                    </div>
                </div>

                <form id="addToCartForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    @* Тук скритият инпут вече ще се пълни от JS *@
                    <input type="hidden" id="finalQuantity" name="quantity" value="1" />

                    <div class="d-grid d-md-block">
                        <button type="submit" class="btn btn-lg px-5 fw-bold text-white shadow-sm py-3" style="background-color: #ff4d05; border-radius: 12px;">
                            <i class="bi bi-cart-plus me-2"></i> ДОБАВИ В КОЛИЧКАТА
                        </button>
                    </div>
                </form>

                <div id="cartMessage" class="mt-3" style="display: none;">
                    <div class="alert alert-success d-flex align-items-center rounded-3 border-0 shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <span>Продуктът беше добавен в количката!</span>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-action="Index" class="text-decoration-none text-muted small">
                        <i class="bi bi-arrow-left"></i> Обратно към каталога
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const unitPrice = @Model.Price.ToString().Replace(",", ".");
        const maxStock = @Model.Quantity;

        function changeQty(delta) {
            const qtyDisplay = document.getElementById('detailQtyInput');
            const finalInput = document.getElementById('finalQuantity');
            const priceDisplay = document.getElementById('displayTotalPrice');

            let currentQty = parseInt(qtyDisplay.value);
            let newQty = currentQty + delta;

            if (newQty >= 1 && newQty <= maxStock) {
                qtyDisplay.value = newQty;
                finalInput.value = newQty; // Обновяваме скритото поле за формата

                // Сменяме цената в реално време
                let total = (newQty * unitPrice).toFixed(2);
                priceDisplay.innerText = total + " €";
            }
        }

        document.getElementById('addToCartForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const formData = new FormData(this);
            const submitBtn = this.querySelector('button[type="submit"]');

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Добавяне...';

            fetch('@Url.Action("Create", "Orders")', {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const msg = document.getElementById('cartMessage');
                    msg.style.display = 'block';

                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-cart-plus me-2"></i> ДОБАВИ В КОЛИЧКАТА';

                    setTimeout(() => {
                        msg.style.display = 'none';
                        window.location.href = '@Url.Action("Index", "Orders")'; // Прехвърляме го в количката
                    }, 1000);
                } else {
                    alert(data.message || 'Възникна грешка при добавянето.');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-cart-plus me-2"></i> ДОБАВИ В КОЛИЧКАТА';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Грешка!';
            });
        });
    </script>
}