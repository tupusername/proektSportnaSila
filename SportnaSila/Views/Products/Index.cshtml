@model IEnumerable<SportnaSila.Models.Products>

<div class="container py-5">
    <h2 class="fw-bold mb-4">Нашите продукти</h2>
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 rounded-4 p-3">
                    <img src="@item.ImgUrl" class="card-img-top rounded-3" style="height: 200px; object-fit: contain;">
                    <div class="card-body">
                        <h5 class="fw-bold">@item.Name</h5>
                        <p class="text-muted small">@item.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="h4 fw-bold text-primary mb-0">@item.Price.ToString("0.00") €</span>
                            
                            <button class="btn btn-primary add-to-cart-btn px-3" data-product-id="@item.Id">
                                <i class="bi bi-cart-plus"></i> Добави
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.add-to-cart-btn').click(function () {
                var btn = $(this);
                var productId = btn.data('product-id');

                btn.prop('disabled', true).text('...');

                $.ajax({
                    url: '/Orders/Create',
                    type: 'POST',
                    data: {
                        productId: productId,
                        quantity: 1,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        btn.text('✅').addClass('btn-success').removeClass('btn-primary');
                        setTimeout(function() {
                            btn.prop('disabled', false).html('<i class="bi bi-cart-plus"></i> Добави').addClass('btn-primary').removeClass('btn-success');
                        }, 1500);
                    },
                    error: function () {
                        alert('Грешка при добавянето.');
                        btn.prop('disabled', false).text('Добави');
                    }
                });
            });
        });
    </script>
}