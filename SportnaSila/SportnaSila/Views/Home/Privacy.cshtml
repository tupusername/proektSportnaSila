@{
    ViewData["Title"] = "За нас и Поверителност";
}

@* Вграждаме иконите за по-готина визия *@
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* Мазно и плавно скролиране директно до анкера */
    html {
        scroll-behavior: smooth;
    }

    /* Тъмносиният цвят от твоя голям хедър на началната страница */
    .home-hero-bg {
        background-color: #1a2230;
        color: white;
        padding: 5rem 0;
    }

    /* Зеленият цвят от бутоните "Виж продуктите" и "Разгледай" */
    .btn-home-green {
        background-color: #2ecc71;
        color: white;
        border: none;
        padding: 0.75rem 1.8rem;
        font-weight: 600;
        border-radius: 8px;
        text-decoration: none;
        display: inline-block;
        transition: background 0.2s;
    }

        .btn-home-green:hover {
            background-color: #27ae60;
            color: white;
        }

    /* Прозрачният бутон "Научи повече" */
    .btn-home-outline {
        background: transparent;
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 0.75rem 1.8rem;
        font-weight: 500;
        border-radius: 8px;
        text-decoration: none;
        display: inline-block;
        transition: all 0.2s;
    }

        .btn-home-outline:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border-color: white;
        }

    /* Малкият зелен надпис (Badge) над заглавието */
    .home-badge {
        background-color: rgba(46, 204, 113, 0.15);
        color: #2ecc71;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.5rem 1.2rem;
        border-radius: 20px;
        display: inline-block;
    }

    /* Оранжевият цвят от логото ти и бутона за количката */
    .brand-orange-text {
        color: #ff4d05;
    }

    /* Белите карти с фини бордери, точно как продуктовите ти кутии */
    .about-feature-card {
        background: #ffffff;
        border: 1px solid #eef2f5;
        border-radius: 16px;
        padding: 2.5rem 2rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.01);
        transition: transform 0.2s;
    }

        .about-feature-card:hover {
            transform: translateY(-3px);
        }

    .icon-box-green {
        color: #2ecc71;
        font-size: 2.5rem;
        margin-bottom: 1rem;
        display: inline-block;
    }

    /* Специален бадж за изброяване на твоите категории */
    .sport-tag {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        color: #495057;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-weight: 500;
        font-size: 0.95rem;
        display: inline-block;
    }

    /* Стил за долната голяма кутия на Поверитеността */
    .privacy-card {
        background-color: #ffffff;
        border-radius: 20px;
        border: 1px solid #eef2f5;
        box-shadow: 0 4px 15px rgba(0,0,0,0.01);
    }
</style>

@* ========================================== *@
@* --- ЧАСТ 1: СЕКЦИЯ "ЗА НАС" (Хоум Пейдж Интерфейс) --- *@
@* ========================================== *@
<div class="home-hero-bg text-center">
    <div class="container">
        <div class="home-badge mb-3">Ново поколение спортна екипировка</div>
        <h1 class="display-4 fw-bold mb-3" style="letter-spacing: -1px;">
            Проектът <span class="brand-orange-text">SportnaSila</span>
        </h1>
        <p class="lead mx-auto mb-4" style="max-width: 650px; color: #a0aec0; font-size: 1.1rem;">
            Твоето място за първокласна екипировка, аксесоари и оборудване, изцяло съобразени с любимите ти спортни дисциплини.
        </p>
        <div class="d-flex justify-content-center gap-3">
            @* РЕМОНТИРАНИЯТ БУТОН ТУК: Вече сочи към правилния контролер *@
            <a asp-controller="Categories" asp-action="Index" class="btn-home-green">Разгледай продуктите</a>
            <a href="#privacy-section" class="btn-home-outline">Поверителност</a>
        </div>
    </div>
</div>

<div class="container py-5 my-2">
    <div class="row align-items-center g-5">
        <div class="col-md-7">
            <h2 class="fw-bold text-dark mb-4" style="font-size: 2.2rem; letter-spacing: -0.5px;">Идеята зад създаването</h2>
            <p class="text-secondary lh-lg mb-3" style="text-align: justify;">
                <strong>SportnaSila</strong> се роди от стремежа да изградим максимално практично, бързо и подредено дигитално пространство за спортната общност в България. Забелязахме, че масовият пазар често е претрупан, а за феновете на по-специфични и стратегически игри е трудно да съберат всичко необходимо на едно място.
            </p>
            <p class="text-secondary lh-lg mb-4" style="text-align: justify;">
                Нашата основна теза при изграждането на каталога беше да дадим равен фокус и сцена както на класическите отборни игри, така и на популярните нишови дисциплини – <strong>тенис на корт и тенис на маса</strong>. Искаме да спестим време на играчите, като им предоставим възможността да намерят хилки, ракети, мрежи и аксесоари в същата платформа, от която поръчват екипировката си за останалите спортове.
            </p>

            @* Изброяване само на твоите реални 6 категории *@
            <h5 class="fw-bold text-dark mb-3">Дисциплините, които поддържаме:</h5>
            <div class="d-flex flex-wrap gap-2">
                <span class="sport-tag">Футбол</span>
                <span class="sport-tag">Бойни спортове</span>
                <span class="sport-tag">Волейбол</span>
                <span class="sport-tag">Баскетбол</span>
                <span class="sport-tag"><i class="bi bi-circle-fill me-1 brand-orange-text" style="font-size: 0.5rem;"></i>Тенис на Корт</span>
                <span class="sport-tag"><i class="bi bi-circle-fill me-1 brand-orange-text" style="font-size: 0.5rem;"></i>Тенис на Маса</span>
            </div>
        </div>

        <div class="col-md-5 text-center">
            @* Оранжевата визуална кутия, съвпадаща с бутона за количка на топката ти *@
            <div class="p-5 rounded-4 border text-white d-flex flex-column align-items-center justify-content-center" style="min-height: 280px; border-radius: 20px; background-color: #ff4d05;">
                <i class="bi bi-lightning-charge display-2 mb-3"></i>
                <h4 class="fw-bold">Тренирай със стил</h4>
                <p class="small mb-0 px-3 opacity-90">Сила, стил и пълна увереност във всяка една секунда от играта.</p>
            </div>
        </div>
    </div>

    @* --- ТРИТЕ СЕКЦИИ С ИКОНИ --- *@
    <div class="row g-4 mt-5 pt-3 mb-5">
        <div class="col-md-4">
            <div class="about-feature-card text-center">
                <div class="icon-box-green">
                    <i class="bi bi-grid-3x3-gap"></i>
                </div>
                <h4 class="h5 fw-bold text-dark mb-3">Обособени категории</h4>
                <p class="text-muted small lh-lg mb-0">Структуриран каталог, където тенисът на маса и корт имат своето полагаемо място с качествено подбрани артикули.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="about-feature-card text-center">
                <div class="icon-box-green">
                    <i class="bi bi-cart-check"></i>
                </div>
                <h4 class="h5 fw-bold text-dark mb-3">Оптимално пазаруване</h4>
                <p class="text-muted small lh-lg mb-0">Край на разпокъсаните поръчки из десетки сайтове. Всичко за твоя мач или тренировка се събира в една обща количка.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="about-feature-card text-center">
                <div class="icon-box-green">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h4 class="h5 fw-bold text-dark mb-3">Защитени профили</h4>
                <p class="text-muted small lh-lg mb-0">Сигурността на потребителите е наш основен закон. Всички твои данни, профили и поръчки са напълно криптирани.</p>
            </div>
        </div>
    </div>

    <hr class="my-5 opacity-25">

    @* ========================================== *@
    @* --- ЧАСТ 2: ПОЛИТИКА ЗА ПОВЕРИТЕЛНОСТ --- *@
    @* ========================================== *@
    <div id="privacy-section" class="privacy-card p-4 p-md-5 mt-4">
        <div class="d-flex align-items-center mb-4">
            <div class="icon-box-green mb-0 me-3" style="font-size: 2rem;"><i class="bi bi-file-earmark-lock-fill"></i></div>
            <div>
                <h2 class="fw-bold text-dark h3 mb-1" style="letter-spacing: -0.5px;">Политика за поверителност</h2>
                <p class="text-muted small mb-0">В сила за потребителите и клиентите на SportnaSila</p>
            </div>
        </div>

        <p class="text-secondary lh-lg mb-4">
            В стремежа си да изградим сигурна общност за спорт, защитата на Вашите лични данни е наш фундаментален приоритет. Ние събираме и обработваме информация единствено съгласно законовите рамки и правила за електронна търговия в България.
        </p>

        <div class="mb-4">
            <h4 class="fw-bold text-dark h6 mb-2" style="font-size: 1.05rem;">1. Информация, необходима за изпълнение на поръчки</h4>
            <p class="text-secondary small lh-lg">
                За да извършим точна доставка на избраните от Вас стоки, ракети, хилки или аксесоари, нашата система изисква следните минимални данни: Име, Фамилия, Телефонен номер за връзка, Електронна поща и Адрес. Тази информация се препраща по сигурен път към нашите партньори – лицензирани куриерски компании.
            </p>
        </div>

        <div class="mb-4">
            <h4 class="fw-bold text-dark h6 mb-2" style="font-size: 1.05rem;">2. Криптиране и сигурност на акаунтите</h4>
            <p class="text-secondary small lh-lg">
                Всички потребителски пароли и чувствителни данни в базата данни на SportnaSila се съхраняват в криптиран вид. Ние прилагаме софтуерни филтри, които предотвратяват нерегламентиран достъп и гарантираме, че Вашите данни няма да бъдат продавани или отдавани на трети лица за външни маркетингови кампании.
            </p>
        </div>

        <div class="mb-0">
            <h4 class="fw-bold text-dark h6 mb-2" style="font-size: 1.05rem;">3. Потребителски права (GDPR)</h4>
            <p class="text-secondary small lh-lg mb-0">
                Всеки регистриран потребител разполага с правото по всяко време да редактира личната информация в профила си или да се възползва от „правото да бъдеш забравен“, като изпрати официално искане за пълно заличаване на акаунта си от системната ни база данни.
            </p>
        </div>
    </div>
</div>