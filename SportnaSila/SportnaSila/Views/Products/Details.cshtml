@model SportnaSila.Models.Products

@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-5">
    @* Горна навигация *@
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left me-2"></i>Обратно към каталога
        </a>
    </div>

    @* Основна карта с детайли *@
    <div class="card shadow-sm rounded-4 p-4 border-0 bg-white">
        <div class="row g-4">

            @* Лява колона: Снимка на продукта *@
            <div class="col-md-5 text-center">
                @if (!string.IsNullOrEmpty(Model.ImgUrl))
                {
                    <img src="@Model.ImgUrl" class="img-fluid rounded-4 shadow-sm" style="max-height: 400px; object-fit: contain;" alt="@Model.Name" />
                }
                else
                {
                    <div class="bg-light rounded-4 d-flex align-items-center justify-content-center shadow-sm" style="height: 350px;">
                        <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                    </div>
                }
            </div>

            @* Дясна колона: Информация за продукта *@
            <div class="col-md-7 d-flex flex-column justify-content-between">
                <div>
                    <span class="badge bg-light text-dark mb-2 px-3 py-2 rounded-pill border">
                        <i class="bi bi-tag-fill me-1 text-primary"></i> @(Model.Category?.Name ?? "Няма категория")
                    </span>
                    <span class="badge bg-light text-dark mb-2 px-3 py-2 rounded-pill border">
                        <i class="bi bi-award-fill me-1 text-warning"></i> @(Model.Brand?.BrandName ?? "Няма марка")
                    </span>

                    <h1 class="fw-bold text-dark mt-2 mb-3">@Model.Name</h1>

                    <div class="d-flex align-items-center mb-4">
                        @* Наличността е премахната от тук *@
                        <h2 class="fw-extrabold text-success m-0">@Model.Price.ToString("F2") €</h2>
                    </div>

                    <h5 class="fw-bold text-secondary border-bottom pb-2">Описание на продукта</h5>
                    <p class="text-muted lh-base" style="white-space: pre-line;">
                        @(string.IsNullOrEmpty(Model.Description) ? "Този продукт няма описание." : Model.Description)
                    </p>
                </div>

                @* Бутон за купуване / Добавяне в количката *@
                <div class="mt-4 pt-3 border-top">
                    <form id="addToCartForm" class="m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" />

                        @if (Model.Quantity > 0)
                        {
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <label for="quantityInput" class="fw-bold text-secondary m-0">Брой:</label>
                                @* Инпут за избор на количество с ограничение до наличните бройки *@
                                <input type="number" id="quantityInput" name="quantity" class="form-control text-center fw-bold rounded-3 shadow-sm"
                                       value="1" min="1" max="@Model.Quantity" style="width: 90px; height: 48px; font-size: 1.1rem;" />
                            </div>

                            <button type="submit" class="btn btn-lg px-5 fw-bold text-white shadow-sm btn-cart" style="background-color: #ff4d05; border-radius: 12px; transition: transform 0.2s; height: 48px;">
                                <i class="bi bi-cart-plus me-2"></i> ДОБАВИ В КОЛИЧКАТА
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-danger d-inline-flex align-items-center rounded-3 px-4 py-2 m-0">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> Продуктът е временно изчерпан!
                            </div>
                        }
                    </form>

                    <div id="cartMessage" class="mt-3" style="display: none;">
                        <div class="alert alert-success d-flex align-items-center rounded-3 shadow-sm m-0">
                            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                            <span class="fw-bold">Продуктът беше добавен в количката успешно!</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('addToCartForm').addEventListener('submit', function (e) {
            e.preventDefault(); // Спираме презареждането

            const formData = new FormData(this);
            const submitBtn = this.querySelector('button[type="submit"]');

            // Визуална обратна връзка - деактивираме бутона временно
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Добавяне...';

            fetch('@Url.Action("Create", "Orders")', {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Показваме съобщение за успех
                    const msg = document.getElementById('cartMessage');
                    msg.style.display = 'block';

                    // Връщаме бутона в нормално състояние
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-cart-plus me-2"></i> ДОБАВИ В КОЛИЧКАТА';

                    // Скриваме съобщението след 3 секунди
                    setTimeout(() => { msg.style.display = 'none'; }, 3000);
                } else {
                    alert(data.message || "Грешка при добавянето в количката.");
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-cart-plus me-2"></i> ДОБАВИ В КОЛИЧКАТА';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Грешка!';
            });
        });
    </script>
}