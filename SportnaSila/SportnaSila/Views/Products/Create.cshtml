@model SportnaSila.Models.Products

@{
    ViewData["Title"] = "Добави продукт";
}

<div class="container py-4">
    <h1 class="fw-bold">Създай нов продукт</h1>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" class="shadow-sm p-4 bg-white rounded-4">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">Име на продукта</label>
                    <input asp-for="Name" class="form-control" placeholder="напр. Футболна топка" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label fw-bold">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ImgUrl" class="control-label fw-bold">URL на снимка</label>
                    <input asp-for="ImgUrl" class="form-control" />
                    <span asp-validation-for="ImgUrl" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Price" class="control-label fw-bold">Цена (€)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Quantity" class="control-label fw-bold">Количество</label>
                        <input asp-for="Quantity" class="form-control" type="number" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="control-label fw-bold">Категория</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                        <option value="">-- Избери категория --</option>
                    </select>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="BrandId" class="control-label fw-bold">Марка</label>
                    <select asp-for="BrandId" class="form-control" asp-items="ViewBag.BrandId">
                        <option value="">-- Избери марка --</option>
                    </select>
                </div>

                <div class="form-group d-flex gap-2">
                    <input type="submit" value="Създай продукт" class="btn btn-success px-4 rounded-pill" />
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Назад</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}